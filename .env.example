# Google OAuth2 Client ID (from Google Cloud Console)
# Use "Desktop app" for PKCE-only (no secret); use "Web application" + GOOGLE_CLIENT_SECRET if needed.
GOOGLE_CLIENT_ID=

# Google OAuth2 Client Secret — required only if your OAuth client is "Web application" type
GOOGLE_CLIENT_SECRET=

# Ollama API base URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Override SQLite database location (default: platform user data dir)
DATABASE_PATH=

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Email sync interval in milliseconds (default: 300000 / 5 minutes)
SYNC_INTERVAL_MS=300000
