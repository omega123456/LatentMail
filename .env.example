# Optional overrides for local development only.
# The app ships with a built-in Desktop OAuth client ID (PKCE, no secret).
# Set GOOGLE_CLIENT_ID here only if you want to use a different Desktop client.

# GOOGLE_CLIENT_ID=

# Override SQLite database location (default: platform user data dir)
# DATABASE_PATH=

# Logging level: debug, info, warn, error (default: error)
# LOG_LEVEL=info
