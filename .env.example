# Google OAuth2 Client ID (Desktop type, from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Ollama API base URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Override SQLite database location (default: platform user data dir)
DATABASE_PATH=

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Email sync interval in milliseconds (default: 300000 / 5 minutes)
SYNC_INTERVAL_MS=300000
