# Optional overrides for local development only.
# The app ships with a built-in Desktop OAuth client ID when secrets are not set.
# For a custom OAuth client, set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET in electron/secrets.ts (see secrets.example.ts).
# Set GOOGLE_CLIENT_ID here only if you want to override the client ID for this run.

# GOOGLE_CLIENT_ID=

# Override SQLite database location (default: platform user data dir)
# DATABASE_PATH=

# Logging level: debug, info, warn, error (default: error)
# LOG_LEVEL=info
