{
  "name": "mailclient-app",
  "version": "0.1.0",
  "description": "A cross-platform desktop email client with AI integration",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration=production",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').cpSync('electron/prompts', 'dist-electron/prompts', {recursive: true})\"",
    "build:all": "ng build --configuration=electron && yarn build:electron",
    "electron:dev": "yarn build:electron && npx concurrently -n ng,electron -c blue,green \"ng serve\" \"npx wait-on http://localhost:4200 && npx cross-env NODE_ENV=development electron .\"",
    "electron:start": "yarn build:all && electron .",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "package": "yarn build:all && electron-forge package",
    "make": "yarn build:all && electron-forge make"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@angular/animations": "^21.1.4",
    "@angular/cdk": "^21.1.4",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.1.4",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ngrx/signals": "^21.0.1",
    "@tiptap/core": "^3.19.0",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "dompurify": "^3.3.1",
    "dotenv": "^16.4.5",
    "electron-log": "^5",
    "fastq": "^1.20.1",
    "imapflow": "^1.2.9",
    "mailparser": "^3.7.0",
    "nodemailer": "^8.0.1",
    "rxjs": "~7.8.0",
    "sql.js": "^1.14.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mailparser": "^3.4.5",
    "@types/nodemailer": "^7.0.9",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^40.4.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
  }
}
