{
  "name": "LatentMail",
  "version": "0.1.0",
  "description": "A cross-platform desktop email client with AI integration",
  "author": "LatentMail",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration=production",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').cpSync('electron/prompts', 'dist-electron/prompts', {recursive: true})\"",
    "build:all": "ng build --configuration=electron && yarn build:electron",
    "electron:dev": "yarn build:electron && npx concurrently -n ng,electron -c blue,green \"ng serve --port 4201\" \"npx wait-on http://localhost:4201 && npx cross-env NODE_ENV=development electron .\"",
    "electron:start": "yarn build:all && electron .",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:backend": "tsc -p tsconfig.test.json && node -e \"require('fs').cpSync('electron/prompts', 'dist-test/electron/prompts', {recursive: true})\" && node scripts/run-electron-tests.js",
    "test:backend:parallel": "tsc -p tsconfig.test.json && node -e \"require('fs').cpSync('electron/prompts', 'dist-test/electron/prompts', {recursive: true})\" && node scripts/run-parallel-tests.js",
    "test:frontend": "ng build --configuration=electron && yarn build:electron && tsc -p tsconfig.test.json && node -e \"require('fs').cpSync('electron/prompts', 'dist-test/electron/prompts', {recursive: true})\" && node scripts/run-frontend-tests.js",
    "test:frontend:run": "ng build --configuration=electron && tsc -p tsconfig.test.json && node -e \"require('fs').cpSync('electron/prompts', 'dist-test/electron/prompts', {recursive: true})\" && node scripts/run-frontend-tests.js",
    "test:frontend:list": "node scripts/run-frontend-tests.js --list",
    "test:frontend:update-screenshots": "yarn test:frontend -- --update-snapshots=all",
    "test:full-suite": "yarn test:backend:parallel --check-coverage=90 && yarn test:frontend --check-coverage=90",
    "package": "yarn build:all && electron-builder --dir",
    "make": "yarn build:all && electron-builder",
    "build:native": "node -e \"if(process.platform==='win32'){const{execSync}=require('child_process');const ev=require('electron/package.json').version;execSync('node-gyp rebuild --target='+ev+' --arch=x64 --dist-url=https://electronjs.org/headers',{stdio:'inherit',cwd:'native/win32-drop-target'})}else{console.log('Skipping native addon build (not Windows)')}\"",
    "build:icons": "node scripts/build-icons.mjs",
    "postinstall": "node scripts/create-secrets.js && npx @electron/rebuild -f -w better-sqlite3"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "yarn@1.22.22",
  "build": {
    "appId": "com.latentmail.app",
    "productName": "LatentMail",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist-electron/**",
      "dist/**",
      "assets/**",
      "native/**"
    ],
    "asar": true,
    "asarUnpack": [
      "**/native/**/*.node",
      "**/better-sqlite3/**/*.node",
      "**/sqlite-vec/**",
      "**/sqlite-vec-darwin-arm64/**",
      "**/sqlite-vec-darwin-x64/**",
      "**/sqlite-vec-linux-arm64/**",
      "**/sqlite-vec-linux-x64/**",
      "**/sqlite-vec-windows-x64/**"
    ],
    "icon": "assets/icons/icon",
    "protocols": [
      {
        "name": "LatentMail Mailto",
        "schemes": [
          "mailto"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "executableName": "LatentMail",
      "extraFiles": [
        {
          "from": "latentmail-cli.cmd",
          "to": "latentmail-cli.cmd"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/nsis-include.nsh"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "extraFiles": [
        {
          "from": "latentmail-cli",
          "to": "MacOS/latentmail-cli"
        }
      ]
    },
    "dmg": {}
  },
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@ngrx/signals": "^21.1.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-code-block": "3.22.3",
    "@tiptap/extension-code-block-lowlight": "3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/extensions": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.3",
    "electron-log": "^5",
    "fastq": "^1.20.1",
    "highlight.js": "11.11.1",
    "html-to-text": "9.0.5",
    "iconv-lite": "^0.7.2",
    "imapflow": "^1.3.1",
    "lowlight": "3.3.0",
    "luxon": "^3.7.2",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "ng2-pdfjs-viewer": "^25.0.18",
    "node-addon-api": "^8.7.0",
    "nodemailer": "^8.0.5",
    "psl": "^1.15.0",
    "rxjs": "~7.8.2",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.9",
    "tslib": "^2.8.1",
    "umzug": "^3.8.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@bcoe/v8-coverage": "^1.0.2",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^5.2.3",
    "@types/html-to-text": "^9.0.4",
    "@types/luxon": "^3.7.1",
    "@types/mailparser": "^3.4.6",
    "@types/mocha": "^10.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/smtp-server": "^3.5.13",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "icojs": "^0.20.2",
    "mocha": "^11.7.5",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.9",
    "selfsigned": "^5.5.0",
    "smtp-server": "^3.18.4",
    "typescript": "~5.9.3",
    "undici": "^8.0.2",
    "wait-on": "^9.0.4"
  }
}
