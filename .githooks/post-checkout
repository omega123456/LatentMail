#!/usr/bin/env bash
set -e

old="$1"
new="$2"
flag="$3"
null="0000000000000000000000000000000000000000"

# If old == null -> initial checkout (new worktree)
# Delegate to standalone script (install deps + copy context/agent files from other worktree)
if [ "$old" = "$null" ]; then
  repo_root="$(pwd)"
  if [ -f "$repo_root/scripts/setup-worktree.sh" ]; then
    "$repo_root/scripts/setup-worktree.sh"
  else
    echo "Detected new worktree; running yarn install..."
    yarn install
    npx @electron/rebuild -f -w better-sqlite3
  fi
fi
